# Database Configuration
# For Docker Compose: postgresql://postgres:postgres@db:5432/app
# For Local: postgresql://postgres:password@localhost:5432/classroom_db
DATABASE_URL=postgresql://postgres:postgres@db:5432/app

# API Configuration
API_V1_STR=/api/v1
PROJECT_NAME=Classroom Reservation System

# Security (generate new values for production)
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# SQLAlchemy Configuration
SQLALCHEMY_ECHO=False
